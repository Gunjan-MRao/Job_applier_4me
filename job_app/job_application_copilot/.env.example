# Copy this file to .env and fill in your values.
# Do NOT commit your actual .env file to git.

APP_NAME=Job Application Copilot
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

# SQLite database — stored inside the project folder on your machine
DATABASE_URL=sqlite:///./job_application_copilot.db

# ---------------------------------------------------------------------------
# AI AGENT API KEYS — Add these to unlock the Agent Debate panel
# All 4 have a free tier. Reddit Oracle always works without any key.
# ---------------------------------------------------------------------------

# Agent 1 — The Optimist (Gemini 1.5 Flash)
# FREE: https://aistudio.google.com/app/apikey
# Click 'Get API Key' -> 'Create API key' -> copy it here
GEMINI_API_KEY=

# Agent 2 — The Realist (Mistral-7B via HuggingFace)
# FREE: https://huggingface.co/settings/tokens
# Sign up -> Settings -> Access Tokens -> New token (read) -> copy here
HF_API_KEY=

# Agent 3 — The Tactician (GPT-4o-mini via OpenAI)
# FREE TRIAL / PAY-AS-YOU-GO: https://platform.openai.com/api-keys
# New account gets $5 free credit. GPT-4o-mini is very cheap (~$0.0001/call)
OPENAI_API_KEY=

# Agent 4 — The Risk Analyst (Claude Haiku via Anthropic)
# FREE TIER: https://console.anthropic.com/settings/keys
# New account gets free credits. Claude Haiku is the cheapest Claude model
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Storage paths (relative to job_application_copilot/)
# ---------------------------------------------------------------------------
STORAGE_DIR=storage
RESUME_DIR=storage/resumes
GENERATED_DIR=storage/generated
SCREENSHOT_DIR=storage/screenshots
LOG_DIR=storage/logs
