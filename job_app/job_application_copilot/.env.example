# Copy this file to .env and fill in your values.
# Do NOT commit your actual .env file to git.

APP_NAME=Job Application Copilot
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

# SQLite database — stored inside the project folder on your machine
DATABASE_URL=sqlite:///./job_application_copilot.db

# Add your OpenAI or Anthropic key here for resume tailoring / cover letter generation
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Storage paths (relative to job_application_copilot/)
STORAGE_DIR=storage
RESUME_DIR=storage/resumes
GENERATED_DIR=storage/generated
SCREENSHOT_DIR=storage/screenshots
LOG_DIR=storage/logs
