# Copy this file to .env (in this same job_application_copilot/ folder) and fill
# in your values. Do NOT commit your actual .env file — it is gitignored.
#
# The app is designed to run 100% FREE end-to-end. Every key below is optional:
# with none set, the app runs the full flow on realistic MOCK job listings and
# writes cover letters / cold emails from built-in offline templates. Add the
# Adzuna keys below to pull REAL UK jobs, and GROQ_API_KEY to unlock AI-written
# drafts and real email sending.

APP_NAME=Job Application Copilot
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

# SQLite database — stored inside the project folder on your machine
DATABASE_URL=sqlite:///./storage/jobs.db

# ---------------------------------------------------------------------------
# LLM — Groq is the FREE primary provider (used for AI cover letters + emails)
# Get a free key at: https://console.groq.com  (no credit card required)
# Model used: llama-3.3-70b-versatile
# Without this key the app falls back to solid offline templates.
# ---------------------------------------------------------------------------
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# EMAIL / SMTP — free cold-email sending (e.g. Gmail)
# For Gmail: turn on 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords and paste it as EMAIL_PASSWORD
# (this is NOT your normal Gmail login password).
# ---------------------------------------------------------------------------
EMAIL_ADDRESS=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# ---------------------------------------------------------------------------
# OPTIONAL — extra free/paid LLM fallbacks (only used if GROQ_API_KEY is unset)
# ---------------------------------------------------------------------------
# Gemini 1.5 Flash — FREE: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Mistral-7B via HuggingFace — FREE: https://huggingface.co/settings/tokens
HF_API_KEY=
# GPT-4o-mini (paid) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Claude Haiku (paid) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# JOB DATA — Adzuna is the PRIMARY source for real UK jobs (free, no card).
# Register (2 min) at: https://developer.adzuna.com/  then copy your App ID +
# App Key here. Without these two the app uses MOCK listings so the flow still
# works end-to-end — but you will NOT see live vacancies until they are set.
# ---------------------------------------------------------------------------
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---------------------------------------------------------------------------
# JOB DATA — Reed is the SECONDARY source (free API key, merged on top of
# Adzuna for extra UK coverage). Register at: https://www.reed.co.uk/developers
# ---------------------------------------------------------------------------
REED_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — recruiter-email finders for cold outreach
# ---------------------------------------------------------------------------
HUNTER_API_KEY=
APOLLO_API_KEY=

# ---------------------------------------------------------------------------
# Storage paths (relative to job_application_copilot/)
# ---------------------------------------------------------------------------
STORAGE_DIR=storage
RESUME_DIR=storage/resumes
GENERATED_DIR=storage/generated
SCREENSHOT_DIR=storage/screenshots
LOG_DIR=storage/logs
