# ---------------------------------------------------------------------------
# Streamlit secrets template — for Streamlit Community Cloud deployment.
#
# HOW TO USE
#   * Local:  copy this file to `.streamlit/secrets.toml` and fill in values.
#             The real `secrets.toml` is gitignored — NEVER commit it.
#   * Cloud:  do NOT upload a file. Instead open your app on
#             https://share.streamlit.io  →  ⋮  →  Settings  →  Secrets, and
#             paste the same key = "value" lines below into that editor.
#
# Every key is OPTIONAL. With none set, the app still runs the full flow on
# built-in SAMPLE job listings (and shows a clear banner saying so). Add the
# Adzuna keys for REAL UK jobs, and GROQ_API_KEY for AI-written drafts.
#
# These key names match .env.example exactly. app.py copies them into the
# environment at startup, so the same backend code reads them either way.
# ---------------------------------------------------------------------------

# --- LLM (AI cover letters + cold emails) ---------------------------------
# Free key: https://console.groq.com   (model: llama-3.3-70b-versatile)
GROQ_API_KEY = ""
# Optional free fallback: https://aistudio.google.com/app/apikey
GEMINI_API_KEY = ""

# --- JOB DATA (real UK vacancies) -----------------------------------------
# Adzuna is PRIMARY (free, no card): https://developer.adzuna.com/
ADZUNA_APP_ID = ""
ADZUNA_APP_KEY = ""
# Reed is SECONDARY (free): https://www.reed.co.uk/developers
REED_API_KEY = ""

# --- EMAIL / SMTP (optional cold-email sending) ---------------------------
# For Gmail use an App Password: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS = ""
EMAIL_PASSWORD = ""
